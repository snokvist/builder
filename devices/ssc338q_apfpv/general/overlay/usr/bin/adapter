#!/bin/sh
ssid=$(fw_printenv -n wlanssid || echo OpenIPC)
pass=$(fw_printenv -n wlanpass || echo 12345678)
chan=$(fw_printenv -n wlanchan || echo 149)
wlanpwr=$(fw_printenv -n wlanpwr || echo 1000)
[ "$chan" -le 13 ] && mode=g || mode=a

set_config() {
cat << EOF > /tmp/hostapd.conf
ctrl_interface=/var/run/hostapd
interface=wlan0

# ---------- RADIO ----------
ieee80211d=0
hw_mode=$mode
channel=$chan
ieee80211n=1
ieee80211ac=0
ht_capab=[HT40+][SHORT-GI-20][SHORT-GI-40][TX-STBC][RX-STBC1][LDPC]
vht_oper_chwidth=0
wmm_enabled=1
require_ht=1
beacon_int=100
dtim_period=2
max_num_sta=4

# ---------- SECURITY / SSID ----------
rsn_pairwise=CCMP
wpa=2
ssid=$ssid
wpa_passphrase=$pass

# ---------- CLIENT TIME-OUTS ----------
ap_max_inactivity=86400
disassoc_low_ack=1
skip_inactivity_poll=1
uapsd_advertisement_enabled=1
EOF
}

case "$1" in
	setup)
		for card in $(lsusb | awk '{print $6}' | uniq); do
			case "$card" in
				"0bda:8812" | "0bda:881a" | "0b05:17d2" | "2357:0101" | "2604:0012")
					driver=88XXau
					;;

				"0bda:a81a")
					driver=8812eu
					;;

				"0bda:f72b" | "0bda:b733")
					driver=8733bu
					;;
			esac
		done

		if [ -z "$driver" ]; then
			echo "Wireless module not detected!"
			exit 1
		fi

		echo "Detected driver: $driver"
		modprobe "$driver" rtw_tx_pwr_by_rate=0 rtw_tx_pwr_lmt_enable=0

		[ "$chan" -le 13 ] && rate=0x8D || rate=0xB7
		echo "$rate" > $(ls /proc/net/*/wlan0/rate_ctl)

		iw wlan0 set txpower fixed $wlanpwr
                iw wlan0 set txpower limit $wlanpwr
		;;

	start)
		set_config
		hostapd /tmp/hostapd.conf -B
		udhcpd -S
		;;

	stop)
		killall -q udhcpd wpa_supplicant
		;;

	*)
		echo "Usage: $0 {setup|start|stop}"
		exit 1
		;;
esac
