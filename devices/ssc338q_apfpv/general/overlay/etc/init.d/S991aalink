#!/bin/sh

case "$1" in
        start)
                echo "Starting aalink..."
                kill -9 $(pidof aalink.sh) 2> /dev/null
                sleep 10
                aalink.sh &
                ;;

        stop)
                echo "Stopping msposd..."
                kill -9 $(pidof aalink.sh)
                ;;

        *)
                echo "Usage: $0 {start|stop}"
                exit 1
                ;;
esac
