#!/bin/sh

# Read the current U-Boot variable “mode”.
#   * `fw_printenv -n mode`     → prints just the value on newer u-boot-tools
#   * If `-n` is not available, fall back to parsing “var=value”.
MODE=$(fw_printenv -n mode 2>/dev/null 2>&1 || true)
[ -z "$MODE" ] && MODE=$(fw_printenv mode 2>/dev/null | cut -d= -f2)

case "$1" in
    start)
        if [ "$MODE" != "aalink" ]; then
            echo "Current mode is '$MODE' – aalink will not be started."
            exit 0        # or `exit 1` if you prefer a non-zero status
        fi

        echo "Starting aalink..."
        pid=$(pidof aalink 2>/dev/null)
        [ -n "$pid" ] && kill -9 "$pid"
        sleep 5
        aalink &
        ;;

    stop)
        echo "Stopping aalink..."
        pid=$(pidof aalink 2>/dev/null)
        [ -n "$pid" ] && kill -9 "$pid"
        echo "Starting normal mode"
        killall -q msposd
        /etc/init.d/S95majestic restart
        sleep 2
        /etc/init.d/S99msposd start
        ;;

    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac
exit 0
