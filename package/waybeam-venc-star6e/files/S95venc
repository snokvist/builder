#!/bin/sh

DAEMON="venc"
DAEMON_PATH="/usr/bin/venc"
DAEMON_CONF="/etc/venc.json"

wait_exit() {
    # Wait up to 15 seconds for venc to fully exit
    i=0
    while [ $i -lt 30 ]; do
        pidof "$DAEMON" >/dev/null 2>&1 || return 0
        sleep 0.5
        i=$((i + 1))
    done
    echo "Warning: $DAEMON did not exit in time, killing"
    killall -9 "$DAEMON" 2>/dev/null
    sleep 1
}

start() {
    if pidof "$DAEMON" >/dev/null 2>&1; then
        echo "$DAEMON already running"
        return 0
    fi
    echo -n "Starting $DAEMON: "
    "$DAEMON_PATH" -c "$DAEMON_CONF" &
    echo "OK"
}

stop() {
    echo -n "Stopping $DAEMON: "
    killall "$DAEMON" 2>/dev/null
    wait_exit
    echo "OK"
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; start ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac
